{
  "name": "@tradchenko/claude-sessions",
  "version": "2.4.0",
  "description": "Multi-agent session manager — TUI picker, search, AI summaries, shared memory system for Claude, Codex, Qwen, Gemini",
  "type": "module",
  "bin": {
    "claude-sessions": "dist/cli.js",
    "cs": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "test": "node --test 'tests/**/*.test.mjs'",
    "test:legacy": "npm run build && node --test test/run.mjs",
    "prepublishOnly": "npm run build",
    "postinstall": "node ./dist/commands/install.js --auto 2>/dev/null || true"
  },
  "keywords": [
    "claude",
    "claude-code",
    "session-manager",
    "tui",
    "cli",
    "ai"
  ],
  "author": "tradchenko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tradchenko/claude-sessions.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "claude-commands/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
